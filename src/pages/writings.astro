---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { BackButton } from "../components/BackButton";

const entries = await getCollection("writings");
const writings = entries
  .map((entry) => {
    const date = entry.data.publishedAt ?? new Date(0);
    return {
      title: entry.data.title,
      month: date.toLocaleString("en-US", {
        month: "short",
        timeZone: "UTC",
      }),
      year: String(date.getUTCFullYear()),
      slug: entry.id,
      sortKey: date.getTime(),
    };
  })
  .sort((a, b) => b.sortKey - a.sortKey);
---

<Layout
  title="Writings | Arik Chakma"
  description="Arik Chakma's thoughts and writings."
>
  <header class="mb-8">
    <BackButton href="/" label="Index" />
    <h1 class="mt-8 mb-0.5">Writings</h1>
    <p class="text-zinc-500">
      Essays, notes, and things I'm thinking about. Subscribe via <a
        href="/feed.xml"
        class="text-black underline decoration-zinc-300 underline-offset-2 hover:no-underline"
        >RSS</a
      >.
    </p>
  </header>

  <ul class="flex flex-col">
    {
      writings.map((w) => (
        <li>
          <a
            href={`/writings/${w.slug}`}
            class="group flex items-baseline gap-2 py-1.5"
          >
            <span class="transition-colors group-hover:text-zinc-500">
              {w.title}
            </span>
            <span class="min-w-10 grow -translate-y-0.5 border-b border-dotted border-zinc-200" />
            <span class="shrink-0 text-sm whitespace-nowrap text-zinc-400 tabular-nums">
              {w.month} {w.year}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</Layout>
